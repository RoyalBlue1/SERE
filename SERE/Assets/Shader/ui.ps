#version 450

in vec4       texcoord0;  // TEXCOORD
in vec4       texcoord1;  // TEXCOORD1
flat in ivec4 texcoord2;  // TEXCOORD2 (flat = no interp)


out vec4 out_color;

struct g_fontBounds_t
{
    vec2 mins;
    vec2 maxs;
};

struct g_imgBounds_t
{
    vec2 mins;
    vec2 size;
};

struct g_styles_t
{
    vec4 color[3];
    float blend;
    float premul;
    float _anon_0;
    float _anon_1;
    float _anon_2;
    float _anon_3;
    float _anon_4;
    float _anon_5;
    float _anon_6;
    float _anon_7;
    float _anon_8;
    float _anon_9;
};

layout(std430, binding = 5) readonly buffer FontBoundsBuffer {
    g_fontBounds_t g_fontBounds[];
};

layout(std430, binding = 6) readonly buffer ImgBoundsBuffer {
    g_imgBounds_t g_imgBounds[];
};

layout(std430, binding = 4) readonly buffer StylesBuffer {
    g_styles_t g_styles[];
};


layout(binding = 0) uniform sampler2D fontTexture;
layout(binding = 1) uniform sampler2D materialTexture;

float saturate(float x)
{
    return clamp(x, 0.0, 1.0);
}

vec2 saturate(vec2 x)
{
    return clamp(x, vec2(0.0), vec2(1.0));
}

vec3 saturate(vec3 x)
{
    return clamp(x, vec3(0.0), vec3(1.0));
}

vec4 saturate(vec4 x)
{
    return clamp(x, vec4(0.0), vec4(1.0));
}

float rsrqt(float x)
{
    return inversesqrt(x);
}

void sincos(float x, out float s, out float c)
{
    s = sin(x);
    c = cos(x);
}

vec4 multisample(sampler2D tex, vec2 uv, vec2 boundsSize, vec2 boundsMins, ivec2 sampleMask)
{
    /*
    r3.zw = saturate(r4.zw + r3.zw);
      r5.x = g_imgBounds[v2.x].mins.x;
      r5.y = g_imgBounds[v2.x].mins.y;
      r5.z = g_imgBounds[v2.x].size.x;
      r5.w = g_imgBounds[v2.x].size.y;
      r3.zw = r3.zw * r5.zw + r5.xy;
      r7.xyzw = materialTexture.SampleLevel(bilinearSampler_s, r3.zw, 0).xyzw;
      r3.xy = r2.xy * float2(0.25,0.25) + r3.xy;
      r3.zw = floor(r3.xy);
      r3.zw = r4.xy ? -r3.zw : float2(-0,-0);
      r3.xy = saturate(r3.xy + r3.zw);
      r3.xy = r3.xy * r5.zw + r5.xy;
      r3.xyzw = materialTexture.SampleLevel(bilinearSampler_s, r3.xy, 0).xyzw;
      r3.xyzw = r7.xyzw + r3.xyzw;
    */
    vec4 r3;
    r3.zw = uv + boundsMins;
    r3.zw = r3.zw * boundsSize;
    vec4 r7 = textureLod(tex, r3.zw, 0);
    // r3.xy = texcoord0.xy * vec2(0.25, 0.25) + r3.xy;
    // r3.zw = floor(r3.xy);
    // r3.zw = sampleMask.xy != ivec2(0) ? -r3.zw : vec2(-0.0, -0.0);
    // r3.xy = saturate(r3.xy + r3.zw);
    // r3.xy = r3.xy * boundsSize + boundsMins;
    // r3.xyzw = texture(tex, r3.xy) + r7;
    // r3.xyzw = r3.xyzw * 0.25;
    // r3.xyzw = clamp(r3.xyzw, 0.0, 1.0);
    // r3.xyzw = r3.xyzw * r3.w;
    return r7;
}

float antiAlias(float x)
{
    return saturate(x);
}

vec4 lerp(vec4 a, vec4 b, float t)
{
    return a + t * (b - a);
}


void main()
{
    vec4 r1, r0;
    int type = texcoord2.w >> 12;
    int styleIndex = texcoord2.z;
    g_styles_t style = g_styles[styleIndex];
    g_imgBounds_t imgBounds = g_imgBounds[texcoord2.x];
    g_fontBounds_t fontBounds = g_fontBounds[texcoord2.z];
    style.color[0] = style.color[0] * style.blend;
    style.color[1] = style.color[1] * style.blend;
    style.color[2] = style.color[2] * style.blend;
    out_color = texture(materialTexture, texcoord1.xy);
    switch (type)
    {
        case 0:
            break;
        case 1:
            break;
        case 2:
        {
            float ellipseSizeX = g_styles[styleIndex]._anon_3;
            float ellipseSizeY = g_styles[styleIndex]._anon_4;
            float innerMask = g_styles[styleIndex]._anon_5;
            float vingette = g_styles[styleIndex]._anon_6;
            float ellipseMetric = ellipseSizeX * ellipseSizeY; //r1.y
            // dFdxCoarse
            r1.zw = texcoord0.zw * vec2(ellipseSizeX, ellipseSizeY);
            float distanceToCenter = sqrt(dot(r1.zw, r1.zw));
            float signedDistanceToCenter = ellipseMetric - distanceToCenter;
            vec2 grad = vec2(
                dFdxCoarse(signedDistanceToCenter),
                dFdyCoarse(signedDistanceToCenter)
            );
            float aa = rsrqt(dot(grad, grad));
            float artistCoverage = saturate(signedDistanceToCenter * vingette + 0.5);
            float aaCoverage = saturate(signedDistanceToCenter * aa);
            float edgeAlpha = min(artistCoverage, aaCoverage);
            if(0 >= edgeAlpha)
            {
                discard;
            }

            vec4 color0 = g_styles[styleIndex].color[0];
            vec4 color1 = g_styles[styleIndex].color[1];
            vec4 color2 = g_styles[styleIndex].color[2];
            
            float blend = g_styles[styleIndex].blend;
            float premul = g_styles[styleIndex].premul;
            float innerSliceBlend = g_styles[styleIndex]._anon_0;
            float sliceBegin = g_styles[styleIndex]._anon_1;
            float sliceEnd = g_styles[styleIndex]._anon_2;
            float innerAA = signedDistanceToCenter - innerMask * ellipseMetric;
            innerMask = saturate(innerAA * ellipseSizeY + 0.5);
            float beginSin;
            float beginCos;
            sincos(sliceBegin, beginSin, beginCos);
            float endCos = -cos(sliceEnd);
            float endSin = -sin(sliceEnd);
            float sliceBeginMask = antiAlias(dot(texcoord0.zw, vec2(beginSin,beginCos))); //r0.z
            float sliceEndMask = antiAlias(dot(texcoord0.zw, vec2(endCos,endSin))); //r0.w
            float sliceMask = (sliceEnd - sliceBegin) >= 3.14159274 ? min(1, sliceBeginMask + sliceEndMask) : min(sliceBeginMask, sliceEndMask);//r0.x  
            vec4 innerColor = vec4(innerSliceBlend * color2.xyz,min(color2.w,color1.w));
            vec4 outerSliceColor = lerp(color2,color0,innerMask);
            vec4 innerSliceColor = lerp(innerColor,color1,innerMask);
            vec4 finalColor = lerp(outerSliceColor, innerSliceColor, sliceMask);

            vec2 boundsMins = imgBounds.mins;
            vec2 boundsSize = imgBounds.size;

            r1.xyzw = multisample(materialTexture, texcoord0.xy,boundsSize,boundsMins,texcoord2.ww & ivec2(16,32));
            r0.x = r0.w * edgeAlpha + -r1.w;
            r0.x = premul * r0.x + r1.w;
            out_color.xyz = r1.xyz * r0.xxx;
            out_color.w = r1.w * blend;
            return;
        }
        default:
            multisample(materialTexture, texcoord0.xy, imgBounds.size, imgBounds.mins, texcoord2.ww & ivec2(16,32));
            break;
    }
}